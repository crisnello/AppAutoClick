<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AutoClick Android"
        android:textSize="24sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/statusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Parado"
        android:textSize="16sp" />

    <Switch
        android:id="@+id/runningSwitch"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Ativar autoclick" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Intervalo" />

    <RadioGroup
        android:id="@+id/intervalGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <RadioButton
            android:id="@+id/interval5s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="5s" />

        <RadioButton
            android:id="@+id/interval10s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="10s" />

        <RadioButton
            android:id="@+id/interval30s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30s" />

        <RadioButton
            android:id="@+id/interval60s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="60s" />

        <RadioButton
            android:id="@+id/interval1m"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1m" />

        <RadioButton
            android:id="@+id/interval1m30s"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1m30s" />
    </RadioGroup>

    <TextView
        android:id="@+id/primaryPointText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Posição 1 não definida" />

    <Button
        android:id="@+id/savePrimaryPointButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Salvar posição 1" />

    <TextView
        android:id="@+id/secondaryPointText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:text="Posição 2 não definida (opcional)" />

    <Button
        android:id="@+id/saveSecondaryPointButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Salvar posição 2" />

    <Button
        android:id="@+id/clearPointsButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Limpar posições salvas" />

    <Button
        android:id="@+id/openAccessibilityButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Abrir acessibilidade" />

</LinearLayout>
